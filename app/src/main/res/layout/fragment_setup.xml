<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clRangeBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="33dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/shape_rounded_block_colored"
        android:paddingBottom="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tvLabelRange"
            style="@style/TextAppearance.AppCompat.Header1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Range"
            android:textColor="@color/background_white"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <EditText
            android:id="@+id/etRangeMin"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginStart="24dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/shape_rounded_textedit_white"
            android:gravity="center"
            android:hint="Min"
            android:inputType="number"
            android:textColor="@color/black"
            app:layout_constraintEnd_toStartOf="@+id/vDash"
            app:layout_constraintHorizontal_chainStyle="spread_inside"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvLabelRange" />

        <View
            android:id="@+id/vDash"
            android:layout_width="20dp"
            android:layout_height="2dp"
            android:layout_marginHorizontal="12dp"
            android:background="@color/background_white"
            app:layout_constraintBottom_toBottomOf="@id/etRangeMin"
            app:layout_constraintEnd_toStartOf="@+id/etRangeMax"
            app:layout_constraintStart_toEndOf="@+id/etRangeMin"
            app:layout_constraintTop_toTopOf="@id/etRangeMin" />

        <EditText
            android:id="@+id/etRangeMax"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginEnd="24dp"
            android:background="@drawable/shape_rounded_textedit_white"
            android:gravity="center"
            android:hint="Max"
            android:inputType="number"
            android:textColor="@color/black"
            app:layout_constraintBottom_toBottomOf="@id/etRangeMin"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/vDash"
            app:layout_constraintTop_toTopOf="@id/etRangeMin" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/background"
        android:text="START"
        app:layout_constraintEnd_toEndOf="@+id/clRangeBlock"
        app:layout_constraintStart_toStartOf="@+id/clRangeBlock"
        app:layout_constraintTop_toBottomOf="@+id/clRangeBlock" />

</androidx.constraintlayout.widget.ConstraintLayout>